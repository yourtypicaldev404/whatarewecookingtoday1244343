# Copy to `.env.local` for local dev (Next.js + deploy server both read this repo).
# gitignored — not committed.
#
# 1) docker compose up -d   (proof server on :6300)
# 2) npm run deploy-server  (separate terminal)
# 3) npm run dev

# Next.js server routes /api/trade and /api/deploy → your local deploy server
DEPLOY_SERVER_URL=http://localhost:3001

# Lace (browser) — same proof URL when testing on this machine
NEXT_PUBLIC_PROOF_SERVER=http://localhost:6300

# deploy-server.mjs — ZK proving (must match running Docker proof server)
PROOF_SERVER_URL=http://127.0.0.1:6300

# Optional: same network as wallet (defaults to mainnet in deploy-server)
# NETWORK_ID=mainnet
