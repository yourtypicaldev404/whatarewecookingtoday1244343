# Copy to `.env.local` for local dev (Next.js + deploy server both read this repo).
# gitignored — not committed.
#
# Same machine (browser + servers): npm run dev:local
#
# Remote server (code runs on VPS, browser + Lace on your laptop):
#   • Open ports on the server: 3000 (Next), 3001 (deploy), 6300 (proof). Example: ufw allow 3000,3001,6300/tcp
#   • Replace YOUR_PUBLIC_IP with the server’s public IP or DNS name.
#   • In Lace → Midnight → Prover server → http://YOUR_PUBLIC_IP:6300
#   • Open the app at http://YOUR_PUBLIC_IP:3000
#   • Safer alternative: SSH tunnel from laptop — ssh -L3000:127.0.0.1:3000 -L6300:127.0.0.1:6300 user@server — then use http://localhost:6300 in Lace.

# Next.js /api/* → deploy server (same host as Next = localhost)
DEPLOY_SERVER_URL=http://localhost:3001

# Documented for tooling; Lace prover URL is set in the wallet (see above).
NEXT_PUBLIC_PROOF_SERVER=http://localhost:6300
# Remote laptop → VPS (uncomment and set IP):
# NEXT_PUBLIC_PROOF_SERVER=http://YOUR_PUBLIC_IP:6300

# deploy-server → proof (always loopback on the server; not your laptop)
PROOF_SERVER_URL=http://127.0.0.1:6300

# Optional: same network as wallet (defaults to preview in deploy-server)
# NETWORK_ID=preview
