# ─── Midnight Preprod Network ────────────────────────────────────────────────
# Source: https://docs.midnight.network/relnotes/overview#preprod
# These are the real Preprod URLs — do NOT change unless switching networks.

NEXT_PUBLIC_NETWORK_ID=preprod

# Midnight Node RPC
NEXT_PUBLIC_MIDNIGHT_NODE_URL=https://rpc.preprod.midnight.network

# Indexer GraphQL (HTTP for queries, WS for subscriptions)
NEXT_PUBLIC_INDEXER_URL=https://indexer.preprod.midnight.network
NEXT_PUBLIC_INDEXER_HTTP=https://indexer.preprod.midnight.network/api/v3/graphql
NEXT_PUBLIC_INDEXER_WS=wss://indexer.preprod.midnight.network/api/v3/graphql/ws

# Proof server — use local Docker by default, or hosted Preprod server
# Local (run: npm run start-proof-server):
NEXT_PUBLIC_PROOF_SERVER=http://localhost:6300
# Hosted Preprod alternative (no Docker needed):
# NEXT_PUBLIC_PROOF_SERVER=https://lace-proof-pub.preprod.midnight.network

# Faucet (for getting tNIGHT → DUST on Preprod)
# https://faucet.preprod.midnight.network/

# ─── Night.fun Protocol ───────────────────────────────────────────────────────

# Treasury key (32 bytes hex) — generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
# Keep SECRET. Only needed server-side for fee collection.
TREASURY_SK=

# Treasury public key (derived from TREASURY_SK) — this goes in the contract constructor
NEXT_PUBLIC_TREASURY_PK=

# ─── Application ──────────────────────────────────────────────────────────────

NEXT_PUBLIC_APP_URL=http://localhost:3000

# ─── IPFS / Pinata (for token images) ────────────────────────────────────────
PINATA_JWT=
NEXT_PUBLIC_PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs

# ─── Database (for token registry, trade history cache) ──────────────────────
# SQLite for local dev, Postgres for production
DATABASE_URL=file:./night-fun.db
# Production:
# DATABASE_URL=postgresql://user:pass@host:5432/nightfun

# ─── Preview Network (for bleeding-edge testing) ─────────────────────────────
# Note: Preview is currently undergoing major network tests (Ledger 8.0 prep)
# Not recommended until new compatibility matrix is published.
# NEXT_PUBLIC_MIDNIGHT_NODE_URL=https://rpc.preview.midnight.network
# NEXT_PUBLIC_INDEXER_HTTP=https://indexer.preview.midnight.network/api/v3/graphql
# NEXT_PUBLIC_INDEXER_WS=wss://indexer.preview.midnight.network/api/v3/graphql/ws
# NEXT_PUBLIC_PROOF_SERVER=https://lace-proof-pub.preview.midnight.network
