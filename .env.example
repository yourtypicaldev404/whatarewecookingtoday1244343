# ─── Midnight network (Mainnet) ──────────────────────────────────────────────
# Wallet Settings → Midnight → Configure Midnight Nodes must match this network.
#
# === Mainnet everywhere (recommended) ===
# Vercel: NEXT_PUBLIC_NETWORK_ID=mainnet + Mainnet indexer/RPC URLs below.
# Railway deploy server: NETWORK_ID=mainnet (same). Wrong network = trades fail with “no public state”.
#
# Override only if you intentionally use Preview or another testnet.

NEXT_PUBLIC_NETWORK_ID=mainnet

# Midnight Node RPC
NEXT_PUBLIC_MIDNIGHT_NODE_URL=https://rpc.mainnet.midnight.network

# Indexer GraphQL (HTTP + WS)
NEXT_PUBLIC_INDEXER_URL=https://indexer.mainnet.midnight.network
NEXT_PUBLIC_INDEXER_HTTP=https://indexer.mainnet.midnight.network/api/v4/graphql
NEXT_PUBLIC_INDEXER_WS=wss://indexer.mainnet.midnight.network/api/v4/graphql/ws

# Proof server — Lace uses this for in-wallet proving (browser must reach it).
# No public mainnet proof server yet — run your own via Docker or use localhost.
NEXT_PUBLIC_PROOF_SERVER=http://localhost:6300
# Local Docker proof (docker compose up -d): also set to http://localhost:6300 and point Lace there.
# NEXT_PUBLIC_PROOF_SERVER=http://localhost:6300

# Faucet — mainnet uses real funds, no faucet. Uncomment for testnets only.
# NEXT_PUBLIC_FAUCET_URL=https://faucet.preview.midnight.network

# Optional: badge label (defaults from id: mainnet→Mainnet)
# NEXT_PUBLIC_NETWORK_LABEL=Mainnet

# ─── Preview (testnet) ────────────────────────────────────────────────────────
# NEXT_PUBLIC_NETWORK_ID=preview
# NEXT_PUBLIC_MIDNIGHT_NODE_URL=https://rpc.preview.midnight.network
# NEXT_PUBLIC_INDEXER_HTTP=https://indexer.preview.midnight.network/api/v4/graphql
# NEXT_PUBLIC_INDEXER_WS=wss://indexer.preview.midnight.network/api/v4/graphql/ws
# NEXT_PUBLIC_PROOF_SERVER=https://proof-server.preview.midnight.network

# ─── Preprod (legacy testnet) ────────────────────────────────────────────────
# NEXT_PUBLIC_NETWORK_ID=preprod
# NEXT_PUBLIC_MIDNIGHT_NODE_URL=https://rpc.preprod.midnight.network
# NEXT_PUBLIC_INDEXER_HTTP=https://indexer.preprod.midnight.network/api/v3/graphql
# NEXT_PUBLIC_INDEXER_WS=wss://indexer.preprod.midnight.network/api/v3/graphql/ws
# NEXT_PUBLIC_PROOF_SERVER=https://lace-proof-pub.preprod.midnight.network

# ─── Stfu.fun protocol ────────────────────────────────────────────────────────

TREASURY_SK=
NEXT_PUBLIC_TREASURY_PK=

# ─── Application ───────────────────────────────────────────────────────────────

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Local dev with Docker proof + local deploy server — copy .env.local.example → .env.local

# Backend that runs ZK deploy + trade (see deploy-server.mjs). Required in production:
# /api/deploy and /api/trade proxy to this URL from the server (never localhost from the browser).
# DEPLOY_SERVER_URL=https://your-app.up.railway.app
#
# Browser-visible deploy server URL for client-side proving (ZK config files served from here).
# Must be reachable from the user's browser (not a private Railway URL).
# NEXT_PUBLIC_DEPLOY_SERVER_URL=https://your-app.up.railway.app
#
# Deploy server (Railway / Node): use NETWORK_ID only — not NEXT_PUBLIC_NETWORK_ID (Vercel-only; wrong on Railway breaks trades).
# NETWORK_ID=mainnet
# Optional overrides (defaults are chosen from NETWORK_ID: mainnet → v4 indexer):
# INDEXER_HTTP=https://indexer.mainnet.midnight.network/api/v4/graphql
# INDEXER_WS=wss://indexer.mainnet.midnight.network/api/v4/graphql/ws
# NODE_RPC=https://rpc.mainnet.midnight.network
#
# ZK proving for deploy-server.mjs (trade/build, deploy).
# No public mainnet proof server yet — run your own via Docker.
PROOF_SERVER_URL=http://127.0.0.1:6300
# Local proof on same machine: docker compose up -d then:
# PROOF_SERVER_URL=http://127.0.0.1:6300
#
# Latency: run proof server on the same host/region as deploy-server (docker compose profile
# "full", or Railway second service from image midnightntwrk/proof-server:8.0.3 + set
# PROOF_SERVER_URL to that service’s private URL). Shared public endpoints add RTT and queueing.

# ─── IPFS / Pinata ────────────────────────────────────────────────────────────
PINATA_JWT=
NEXT_PUBLIC_PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=file:./stfu-fun.db
