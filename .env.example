# в”Ђв”Ђв”Ђ Midnight network (Preview until mainnet) в”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђв”Ђ
# Wallet Settings в†’ Midnight в†’ Configure Midnight Nodes must match this network.
# Override with NEXT_PUBLIC_NETWORK_ID if you use Preprod or another testnet.

NEXT_PUBLIC_NETWORK_ID=preview

# Midnight Node RPC
NEXT_PUBLIC_MIDNIGHT_NODE_URL=https://rpc.preview.midnight.network

# Indexer GraphQL (HTTP + WS)
NEXT_PUBLIC_INDEXER_URL=https://indexer.preview.midnight.network
NEXT_PUBLIC_INDEXER_HTTP=https://indexer.preview.midnight.network/api/v4/graphql
NEXT_PUBLIC_INDEXER_WS=wss://indexer.preview.midnight.network/api/v4/graphql/ws

# Proof server вЂ” local Docker or hosted Preview server
NEXT_PUBLIC_PROOF_SERVER=https://proof-server.preview.midnight.network
# Local alternative:
# NEXT_PUBLIC_PROOF_SERVER=http://localhost:6300

# Faucet (test tokens). Omit for defaults: preview + preprod URLs; mainnet в†’ no button.
# Set to empty to hide the faucet button: NEXT_PUBLIC_FAUCET_URL=
# NEXT_PUBLIC_FAUCET_URL=https://faucet.preview.midnight.network

# Optional: badge label (defaults from id: previewв†’Preview, mainnetв†’Mainnet)
# NEXT_PUBLIC_NETWORK_LABEL=Preview

