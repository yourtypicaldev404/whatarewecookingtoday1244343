# ─── Midnight network (Preview until mainnet) ───────────────────────────────
# Wallet Settings → Midnight → Configure Midnight Nodes must match this network.
# Override with NEXT_PUBLIC_NETWORK_ID if you use Preprod or another testnet.

NEXT_PUBLIC_NETWORK_ID=preview

# Midnight Node RPC
NEXT_PUBLIC_MIDNIGHT_NODE_URL=https://rpc.preview.midnight.network

# Indexer GraphQL (HTTP + WS)
NEXT_PUBLIC_INDEXER_URL=https://indexer.preview.midnight.network
NEXT_PUBLIC_INDEXER_HTTP=https://indexer.preview.midnight.network/api/v4/graphql
NEXT_PUBLIC_INDEXER_WS=wss://indexer.preview.midnight.network/api/v4/graphql/ws

# Proof server — local Docker or hosted Preview server
NEXT_PUBLIC_PROOF_SERVER=https://proof-server.preview.midnight.network
# Local alternative:
# NEXT_PUBLIC_PROOF_SERVER=http://localhost:6300

# Faucet (test tokens). Omit for defaults: preview + preprod URLs; mainnet → no button.
# Set to empty to hide the faucet button: NEXT_PUBLIC_FAUCET_URL=
# NEXT_PUBLIC_FAUCET_URL=https://faucet.preview.midnight.network

# Optional: badge label (defaults from id: preview→Preview, mainnet→Mainnet)
# NEXT_PUBLIC_NETWORK_LABEL=Preview

# ─── Preprod (legacy) ─────────────────────────────────────────────────────────
# NEXT_PUBLIC_NETWORK_ID=preprod
# NEXT_PUBLIC_MIDNIGHT_NODE_URL=https://rpc.preprod.midnight.network
# NEXT_PUBLIC_INDEXER_HTTP=https://indexer.preprod.midnight.network/api/v3/graphql
# NEXT_PUBLIC_INDEXER_WS=wss://indexer.preprod.midnight.network/api/v3/graphql/ws
# NEXT_PUBLIC_PROOF_SERVER=https://lace-proof-pub.preprod.midnight.network

# ─── Night.fun protocol ───────────────────────────────────────────────────────

TREASURY_SK=
NEXT_PUBLIC_TREASURY_PK=

# ─── Application ───────────────────────────────────────────────────────────────

NEXT_PUBLIC_APP_URL=http://localhost:3000

# Backend that runs ZK deploy + trade (see deploy-server.mjs). Required in production:
# /api/deploy and /api/trade proxy to this URL from the server (never localhost from the browser).
# DEPLOY_SERVER_URL=https://your-app.up.railway.app

# ─── IPFS / Pinata ────────────────────────────────────────────────────────────
PINATA_JWT=
NEXT_PUBLIC_PINATA_GATEWAY=https://gateway.pinata.cloud/ipfs

# ─── Database ─────────────────────────────────────────────────────────────────
DATABASE_URL=file:./night-fun.db
